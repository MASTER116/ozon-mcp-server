# Ozon Seller API (required)
# Get credentials: Seller Dashboard → Settings → API Integrations → Seller API
OZON_CLIENT_ID=your_client_id_here
OZON_API_KEY=your_api_key_here

# PostgreSQL
POSTGRES_PASSWORD=

# Redis (optional for dev, required for production)
REDIS_PASSWORD=

# MCP Auth (optional — for remote HTTP access)
MCP_AUTH_TOKEN=

# Server
TRANSPORT=stdio
LOG_LEVEL=INFO
MCP_PORT=8000

# Rate limits
RATE_LIMIT_RPM=100
RATE_LIMIT_WRITE_RPM=10

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
