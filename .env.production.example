# =============================================================================
# Ozon MCP Server — Production Environment
# =============================================================================
# Copy to .env and fill in real values before deploying:
#   cp .env.production.example .env
#
# IMPORTANT: Never commit .env to git!
# =============================================================================

# --- Ozon Seller API (REQUIRED) ---
# Get credentials: https://seller.ozon.ru → Settings → API Integrations
OZON_CLIENT_ID=
OZON_API_KEY=

# --- PostgreSQL ---
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=

# --- Redis ---
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=

# --- MCP Authentication ---
# Bearer token for remote HTTP access (strongly recommended for streamable-http)
# Generate: openssl rand -hex 32
MCP_AUTH_TOKEN=

# --- Server ---
TRANSPORT=streamable-http
MCP_PORT=8000
LOG_LEVEL=INFO

# --- Rate Limits ---
RATE_LIMIT_RPM=100
RATE_LIMIT_WRITE_RPM=10

# --- Circuit Breaker ---
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
